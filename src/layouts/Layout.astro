---
import '../styles/global.css'
import Sidebar from "../components/Sidebar.astro";

const { lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{lang === 'es' ? 'WM SAS | Ingeniería Solar Inteligente' : 'WM SAS | Smart Solar Engineering'}</title>
		<meta
			name="description"
			content={lang === 'es'
				? 'WM SAS diseña e instala sistemas de energía solar a medida para hogares y empresas en Colombia. Calcula tu ahorro y programa una asesoría gratuita.'
				: 'WM SAS designs and installs tailored solar systems for homes and companies in Colombia. Estimate your savings and book a free consultation.'}
		/>
		<meta property="og:title" content={lang === 'es' ? 'WM SAS · Energía solar profesional' : 'WM SAS · Professional Solar Energy'} />
		<meta
			property="og:description"
			content={lang === 'es'
				? 'Implementamos soluciones fotovoltaicas llave en mano con ingeniería certificada, financiamiento y acompañamiento integral.'
				: 'We deliver turnkey PV solutions with certified engineering, financing options, and end-to-end support.'}
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://wmsas.co" />
		<meta property="og:image" content="/images/og-cover.jpg" />
		<meta name="theme-color" content="#1c2554" />
	</head>
	<body>
		<Sidebar lang={lang} />
		<main class="lg:pl-15 fondo">
			<slot />
		</main>
		<script is:inline>
			(() => {
				try {
					const revealElements = document.querySelectorAll('[data-reveal]');
					const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					const supportsObserver = 'IntersectionObserver' in window;
					const enableRevealMotion = () => document.body.classList.add('js-ready');

					if (prefersReduced || !supportsObserver) {
						revealElements.forEach((el) => el.classList.add('is-visible'));
						enableRevealMotion();
					} else {
						const observer = new IntersectionObserver(
							(entries) => {
								entries.forEach((entry) => {
									if (entry.isIntersecting) {
										entry.target.classList.add('is-visible');
									}
								});
							},
							{ threshold: 0.2 }
						);

						revealElements.forEach((el) => observer.observe(el));
						enableRevealMotion();
					}

					const currentLang = ${JSON.stringify(lang)};
					const langToggleTargets = document.querySelectorAll('[data-lang-toggle]');
					const getPathForLang = (code) => (code === 'en' ? '/en/' : '/');
					try {
						const storedLang = localStorage.getItem('preferredLang');
						if (!storedLang) {
							localStorage.setItem('preferredLang', currentLang);
						} else if (storedLang !== currentLang) {
							const target = getPathForLang(storedLang);
							if (!window.location.pathname.startsWith(target)) {
								window.location.href = target;
							}
						}
					} catch (error) {
						/* ignore storage errors */
					}

					langToggleTargets.forEach((trigger) => {
						const tagName = trigger.tagName?.toLowerCase();
						trigger.addEventListener('click', (event) => {
							const nextLang = currentLang === 'es' ? 'en' : 'es';
							const targetPath = getPathForLang(nextLang);
							try {
								localStorage.setItem('preferredLang', nextLang);
							} catch (error) {
								/* ignore storage errors */
							}
							if (tagName === 'a') {
								if (trigger.getAttribute('href') !== targetPath) {
									trigger.setAttribute('href', targetPath);
								}
								return;
							}
							event.preventDefault();
							window.location.href = targetPath;
						});
					});
				} catch (uiError) {
					console.error('UI bootstrap failed', uiError);
				}
			})();
		</script>
	</body>
</html>
