---
import { Icon } from "astro-icon/components";

const { lang = 'es' } = Astro.props;

const rawItems = [
	{
		category: 'ahorro',
		text: {
			es: {
				question: '¿Ahorraré desde el primer día?',
				response:
					'Sí, desde el primer día que tu sistema solar comience a funcionar comenzarás a ver reducción en tu factura de electricidad. Nuestro equipo de expertos evalúa tu consumo para dimensionar correctamente tu instalación.',
			},
			en: {
				question: 'Will I save money from day one?',
				response:
					'Yes. From the first day your solar system operates you will notice a lower bill. Our engineers size the installation according to your demand.',
			},
		},
	},
	{
		category: 'instalacion',
		text: {
			es: {
				question: '¿Cuánto tiempo toma la instalación?',
				response:
					'La instalación típica de un sistema solar residencial toma entre 1 y 3 días, dependiendo del tamaño del sistema y la complejidad del techo. Nos encargamos de todo el proceso de principio a fin.',
			},
			en: {
				question: 'How long does installation take?',
				response:
					'A typical residential system takes 1 to 3 days depending on size and roof complexity. We handle the entire process from start to finish.',
			},
		},
	},
	{
		category: 'mantenimiento',
		text: {
			es: {
				question: '¿Qué mantenimiento requiere?',
				response:
					'Los paneles solares requieren muy poco mantenimiento. Recomendamos una limpieza básica semestral y una revisión técnica anual. Nuestros paneles tienen garantía de 25 años y ofrecemos planes de mantenimiento preventivo.',
			},
			en: {
				question: 'What maintenance is needed?',
				response:
					'Solar panels need very little maintenance. We suggest basic cleaning twice a year and an annual technical check. Panels carry a 25-year warranty and we offer preventive plans.',
			},
		},
	},
	{
		category: 'tramites',
		text: {
			es: {
				question: '¿Necesito permisos especiales?',
				response:
					'Nosotros nos encargamos de todos los trámites y permisos necesarios para la instalación, incluyendo el registro ante el comercializador y los permisos municipales. Solo necesitas proporcionar la documentación básica.',
			},
			en: {
				question: 'Do I need special permits?',
				response:
					'We handle every permit and paperwork required, including utility registration and municipal approvals. You just provide the basic documentation.',
			},
		},
	},
];

const categoryLabels = {
	es: {
		ahorro: 'ahorro',
		instalacion: 'instalación',
		mantenimiento: 'mantenimiento',
		tramites: 'trámites',
	},
	en: {
		ahorro: 'savings',
		instalacion: 'installation',
		mantenimiento: 'maintenance',
		tramites: 'permits',
	},
};

const items = rawItems.map((item) => ({
	category: item.category,
	question: item.text[lang].question,
	response: item.text[lang].response,
}));

const categories = [...new Set(rawItems.map((item) => item.category))];
const defaultCategory = categories[0];

const copy = {
	es: {
		badge: 'preguntas',
		title: 'Resolvemos tus dudas sobre energía solar',
		intro: 'Si no encuentras tu pregunta, agenda una videollamada y aclaramos todo en menos de 24 horas.',
		ctaLabel: '¿Aún tienes dudas?',
		ctaButton: 'Habla con un ingeniero',
	},
	en: {
		badge: 'questions',
		title: 'We answer your solar energy questions',
		intro: 'Book a video call if you do not see your question—we respond in under 24 hours.',
		ctaLabel: 'Still have questions?',
		ctaButton: 'Talk to an engineer',
	},
};

const text = copy[lang];

---

<section id="doubts" class="py-12 lg:py-24 fondo-doubts space-y-10" data-default-category={defaultCategory}>
	<div class="text-center space-y-3" data-reveal>
		<p class="text-xs uppercase tracking-[0.5em] text-primary/60">{text.badge}</p>
		<h2 class="text-4xl font-display text-primary">{text.title}</h2>
		<p class="text-primary/70 max-w-2xl mx-auto text-sm">
			{text.intro}
		</p>
	</div>

	<div class="max-w-5xl mx-auto" data-reveal>
		<div class="flex flex-wrap gap-3 justify-center mb-8">
			{categories.map((category) => (
				<button
					type="button"
					class={`faq-tab px-4 py-2 rounded-full border border-primary/20 text-xs font-semibold uppercase tracking-[0.3em] ${category === defaultCategory ? 'active' : ''}`}
					data-tab={category}
				>
					{categoryLabels[lang][category]}
				</button>
			))}
		</div>

		<ul class="space-y-4" data-faq-list>
			{items.map((item, index) => (
				<li
					class="bg-white/90 shadow-[0_20px_60px_-40px_rgba(0,0,0,0.4)] rounded-2xl border border-primary/10"
					data-faq-item
					data-category={item.category}
					data-index={index}
					data-reveal
					style={`--reveal-delay:${index * 60}ms`}
				>
					<div class="flex flex-wrap md:flex-nowrap items-center gap-4 p-5 cursor-pointer" data-toggle>
						<div class="bg-primary/10 text-primary rounded-2xl p-3">
							<Icon
								name="bombilla-icon"
								class="text-2xl"
							/>
						</div>
						<div class="flex-1 min-w-0">
							<span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.4em] text-primary/60">
								{item.category}
							</span>
							<h3 class="text-lg font-semibold text-primary mt-1">{item.question}</h3>
						</div>
						<button
							class="shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mt-2 md:mt-0"
							aria-label="Desplegar respuesta"
							data-btn
						>
							<Icon
								name="arrow-open-down-icon"
								class="w-5 h-5 [&_path]:fill-white doubt-toggle-icon"
							/>
						</button>
					</div>
					<div class="doubt-response px-5 pb-0" data-response>
						<div>
							<p class="text-sm text-primary/80 leading-relaxed pb-4">{item.response}</p>
						</div>
					</div>
				</li>
			))}
		</ul>
	</div>

	<div class="text-center" data-reveal>
		<p class="text-sm text-primary/70">{text.ctaLabel}</p>
		<a href="https://wa.me/573001234567" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-primary text-white rounded-full text-xs font-semibold uppercase tracking-[0.3em] w-full max-w-xs mx-auto">
			{text.ctaButton}
		</a>
	</div>
</section>

<style>
	.faq-tab.active {
		background: var(--primary);
		color: #fff;
		border-color: var(--primary);
	}
</style>

<script>
const tabs = document.querySelectorAll('[data-tab]');
const faqItems = document.querySelectorAll('[data-faq-item]');
const section = document.getElementById('doubts');

	function activateTab(category) {
		tabs.forEach((tab) => {
			if (tab.getAttribute('data-tab') === category) {
				tab.classList.add('active');
			} else {
				tab.classList.remove('active');
			}
		});

		faqItems.forEach((item) => {
			const itemCategory = item.getAttribute('data-category');
			if (!category || category === itemCategory) {
				item.classList.remove('hidden');
			} else {
				item.classList.add('hidden');
			}
		});
	}

	tabs.forEach((tab) => {
		tab.addEventListener('click', () => {
			activateTab(tab.getAttribute('data-tab')); 
		});
	});

	const toggleRows = document.querySelectorAll('[data-toggle]');

	toggleRows.forEach((row) => {
		row.addEventListener('click', () => {
			const li = row.closest('li');
			const response = li?.querySelector('[data-response]');
			const icon = li?.querySelector('.doubt-toggle-icon');
			const isOpen = response?.classList.contains('open');

			document.querySelectorAll('.doubt-response.open').forEach((openResponse) => {
				openResponse.classList.remove('open');
			});
			document.querySelectorAll('.doubt-toggle-icon.open').forEach((openIcon) => openIcon.classList.remove('open'));

			if (!isOpen) {
				response?.classList.add('open');
				icon?.classList.add('open');
			}
		});
	});

	const initialCategory = section?.getAttribute('data-default-category') || '';
	activateTab(initialCategory);
</script>
