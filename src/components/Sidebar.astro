---
import { Icon } from "astro-icon/components";

const { lang = 'es' } = Astro.props;

const labels = {
    es: {
        inicio: 'Inicio',
        calc: 'Calculadora',
        benefits: 'Beneficios',
        action: 'Acción',
        cases: 'Casos y proyectos',
        faq: 'Preguntas y respuestas',
        contact: 'Contacto',
        language: 'English',
    },
    en: {
        inicio: 'Home',
        calc: 'Calculator',
        benefits: 'Benefits',
        action: 'Action',
        cases: 'Cases & projects',
        faq: 'FAQs',
        contact: 'Contact',
        language: 'Español',
    },
};

const itemsMedio = [
    { icon: 'hogar-icon', link: '#inicio', label: labels[lang].inicio },
    { icon: 'calculadora-icon', link: '#calculadora', label: labels[lang].calc },
    { icon: 'beneficio-icon', link: '#beneficios', label: labels[lang].benefits },
    { icon: 'ajustes-icon', link: '#accion', label: labels[lang].action },
    { icon: 'clasificacion-icon', link: '#cases', label: labels[lang].cases },
    { icon: 'pregunta-y-respuesta-icon', link: '#doubts', label: labels[lang].faq },
    { icon: 'atencion-al-cliente-icon', link: '#', label: labels[lang].contact },
];

const footerActions = [
	{
		icon: 'atencion-al-cliente-icon',
		href: 'https://wa.me/573001234567',
		title: labels[lang].contact,
		type: 'link',
	},
	{
		icon: 'language-icon',
		href: lang === 'es' ? '/en/' : '/',
		title: labels[lang].language,
		type: 'lang',
	},
];

const mobileItems = itemsMedio.slice(0, 4);
---

<div
    class="fixed left-0 top-0 h-screen w-15 shadow-lg flex flex-col justify-between bg-white z-50 hidden lg:flex"
    id="sidebar-desktop"
>
    <div class="px-2 pt-4">
        <img
            src="/images/logo-wmsas.png"
            alt=""
            class="hover:scale-105 transition-all"
        />
    </div>
    <div class="w-full" id="sidebar-nav">
        {
            itemsMedio.map((item) => (
                <a
                    href={item.link}
                    data-section={item.link.replace("#", "")}
                    class="nav-link text-primary text-3xl border-l-6 border-l-transparent px-2 py-4 bg-white w-full flex justify-center transition-all duration-300"
                >
                    <Icon name={item.icon} />
                </a>
            ))
        }
    </div>
    <div class="w-full">
		{
			footerActions.map((action) => (
				<a
					href={action.href}
					class="text-primary text-3xl border-l-6 border-white px-2 py-4 bg-secondary w-full flex justify-center"
					title={action.title}
					aria-label={action.title}
					data-lang-toggle={action.type === 'lang' ? 'true' : undefined}
				>
					<Icon name={action.icon} />
				</a>
			))
		}
	</div>
</div>

<div
    class="fixed bottom-0 left-0 right-0 bg-white shadow-[0_-4px_20px_rgba(0,0,0,0.1)] z-50 lg:hidden"
    id="sidebar-mobile"
>
	<nav class="flex justify-around items-center h-16">
		{
			mobileItems.map((item) => (
				<a
					href={item.link}
					data-section={item.link.replace("#", "")}
					class="mobile-nav-link flex flex-col items-center justify-center gap-1 px-4 py-2 text-primary transition-all duration-300"
				>
					<Icon name={item.icon} class="w-6 h-6" />
					<span class="text-xs font-medium">{item.label}</span>
				</a>
			))
		}
		<button
			type="button"
			class="flex flex-col items-center justify-center gap-1 px-4 py-2 text-primary transition-all duration-300"
			data-lang-toggle
			aria-label={labels[lang].language}
		>
			<Icon name="language-icon" class="w-6 h-6" />
			<span class="text-xs font-medium">{labels[lang].language}</span>
		</button>
	</nav>
</div>

<div class="h-16 lg:hidden"></div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav-link, .mobile-nav-link');

        function setActiveLink(id) {
            navLinks.forEach((link) => {
                const linkId = link.getAttribute('data-section');
                if (linkId === id) {
                    link.classList.add('bg-gray-200', 'border-l-primary', 'text-secondary');
                    link.classList.remove('border-l-transparent', 'bg-white', 'text-primary');
                } else {
                    link.classList.remove('bg-gray-200', 'border-l-primary', 'text-secondary');
                    link.classList.add('border-l-transparent', 'bg-white', 'text-primary');
                }
            });
        }

        navLinks.forEach((link) => {
            link.addEventListener('click', (e) => {
                const href = link.getAttribute('href');
                if (href && href.startsWith('#')) {
                    const target = document.querySelector(href);
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: 'smooth' });
                        history.pushState(null, '', href);
                    }
                }
            });
        });

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        const id = entry.target.getAttribute('id');
                        if (id) setActiveLink(id);
                    }
                });
            },
            { threshold: 0.3 }
        );

        sections.forEach((section) => observer.observe(section));

        setActiveLink('inicio');
    });
</script>
