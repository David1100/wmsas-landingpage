---
const { lang = 'es' } = Astro.props;

const itemsByLang = {
	es: [
		{ image: '/images/fondo-solar-home.jpg', title: 'Residencia García', sector: 'Residencial', subtitle: 'Ahorro del 85% tras 6.4 kWp conectados a red', impact: '$2.4 M COP/mes' },
		{ image: '/images/fondo-solar-home.jpg', title: 'Consultorio López', sector: 'Salud', subtitle: 'Sistema híbrido con respaldo crítico', impact: '6 paneles + baterías' },
		{ image: '/images/fondo-solar-home.jpg', title: 'Restaurante El Sol', sector: 'Comercial', subtitle: '8 kW para cocina eléctrica y vitrinas', impact: '-800 kg CO₂/año' },
		{ image: '/images/fondo-solar-home.jpg', title: 'Casa Suárez', sector: 'Residencial', subtitle: 'Bimestre completo sin costo energético', impact: '4.2 kWp' },
		{ image: '/images/fondo-solar-home.jpg', title: 'Oficinas WM SAS', sector: 'Corporativo', subtitle: 'Autoabastecimiento total con 15 kW', impact: '100% energía limpia' },
	],
	en: [
		{ image: '/images/fondo-solar-home.jpg', title: 'García Residence', sector: 'Residential', subtitle: '85% savings after 6.4 kWp grid-tied', impact: '$2.4 M COP/month' },
		{ image: '/images/fondo-solar-home.jpg', title: 'López Clinic', sector: 'Healthcare', subtitle: 'Hybrid system with critical backup', impact: '6 panels + batteries' },
		{ image: '/images/fondo-solar-home.jpg', title: 'El Sol Restaurant', sector: 'Commercial', subtitle: '8 kW feeding electric kitchen and displays', impact: '-800 kg CO₂/year' },
		{ image: '/images/fondo-solar-home.jpg', title: 'Suárez Home', sector: 'Residential', subtitle: 'Full billing cycle without energy cost', impact: '4.2 kWp' },
		{ image: '/images/fondo-solar-home.jpg', title: 'WM SAS Offices', sector: 'Corporate', subtitle: '15 kW for total self-supply', impact: '100% clean energy' },
	],
};

const metricsByLang = {
	es: [
		{ label: 'kWp instalados', value: '+280' },
		{ label: 'Clientes activos', value: '96' },
		{ label: 'Satisfacción', value: '4.9/5' },
	],
	en: [
		{ label: 'kWp installed', value: '+280' },
		{ label: 'Active clients', value: '96' },
		{ label: 'Satisfaction', value: '4.9/5' },
	],
};

const copy = {
	es: {
		badge: 'Casos reales',
		title: 'Resultados medibles, contratos reales',
		description: 'Hogares, comercios e industrias ya producen su propia energía. Auditamos cada proyecto y reportamos indicadores en tiempo real.',
		cta: 'Ver caso completo',
		prev: 'Caso anterior',
		next: 'Siguiente caso',
		goTo: 'Ir al caso',
	},
	en: {
		badge: 'Real cases',
		title: 'Measurable results, real contracts',
		description: 'Homes, shops, and industries already generate their own energy. We audit every project and report indicators in real time.',
		cta: 'View full case',
		prev: 'Previous case',
		next: 'Next case',
		goTo: 'Go to case',
	},
};

const items = itemsByLang[lang];
const metrics = metricsByLang[lang];
const text = copy[lang];
---

<section id="cases" class="py-12 lg:py-24 space-y-12 relative">
	<div class="max-w-6xl mx-auto px-4 lg:px-8" data-reveal>
		<div class="text-center space-y-4 max-w-4xl mx-auto">
			<p class="text-xs uppercase tracking-[0.5em] text-primary/60">{text.badge}</p>
			<h2 class="text-4xl lg:text-5xl font-display text-primary">{text.title}</h2>
			<p class="text-lg text-primary/70">
				{text.description}
			</p>
		</div>
	</div>

	<div class="max-w-6xl mx-auto px-4 lg:px-8 mt-10">
		<div class="grid gap-4 sm:grid-cols-3">
			{metrics.map((metric, index) => (
				<div class="rounded-2xl border border-primary/10 bg-white/90 p-4 text-center shadow-[0_30px_80px_-70px_rgba(10,15,41,1)]" data-reveal style={`--reveal-delay:${index * 90}ms`}>
					<p class="text-3xl font-display text-primary">{metric.value}</p>
					<p class="text-xs uppercase tracking-[0.4em] text-primary/60">{metric.label}</p>
				</div>
			))}
		</div>
	</div>

	<div class="relative max-w-6xl mx-auto px-4 lg:px-8 mt-12">
		<div class="overflow-hidden" id="slider-container">
			<div class="flex transition-transform duration-500 ease-out" id="slider-track">
				{
					items.map((item, index) => (
						<div class="w-full md:w-1/2 lg:w-1/3 shrink-0 px-3" data-reveal style={`--reveal-delay:${index * 80}ms`}>
							<div class="rounded-[1.5rem] overflow-hidden shadow-[0_40px_90px_-60px_rgba(10,15,41,1)] border border-primary/10 bg-white">
								<div class="relative h-48 md:h-56 overflow-hidden">
									<img src={item.image} alt={item.title} class="w-full h-full object-cover" />
									<div class="absolute inset-0 bg-gradient-to-t from-primary/90 to-transparent"></div>
									<div class="absolute bottom-4 left-4 right-4 flex items-center justify-between text-white text-xs">
										<span class="uppercase tracking-[0.4em] text-white/70">{item.sector}</span>
										<span class="px-3 py-1 rounded-full bg-white/20">{item.impact}</span>
									</div>
								</div>
					<div class="p-6 space-y-2">
						<h3 class="text-xl font-display text-primary">{item.title}</h3>
						<p class="text-sm text-primary/70">{item.subtitle}</p>
						<button class="mt-2 text-sm font-semibold text-primary inline-flex items-center gap-2">
							{text.cta} <span>→</span>
						</button>
					</div>
							</div>
						</div>
					))
				}
			</div>
		</div>

		<button
			id="slider-prev"
			class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-primary items-center justify-center shadow-lg hover:bg-primary/80 transition-colors z-10"
			aria-label={text.prev}
		>
			<svg class="w-5 h-5 md:w-6 md:h-6 text-white" viewBox="0 0 1920 1920" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
				<path d="m1394.006 0 92.299 92.168-867.636 867.767 867.636 867.636-92.299 92.429-959.935-960.065z" fill-rule="evenodd" />
			</svg>
		</button>

		<button
			id="slider-next"
			class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 w-10 h-10 md:w-12 md:h-12 rounded-full bg-primary items-center justify-center shadow-lg hover:bg-primary/80 transition-colors z-10"
			aria-label={text.next}
		>
			<svg class="w-5 h-5 md:w-6 md:h-6 text-white" viewBox="0 0 1920 1920" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
				<path d="M526.299 0 434 92.168l867.636 867.767L434 1827.57l92.299 92.43 959.935-960.065z" fill-rule="evenodd" />
			</svg>
		</button>
		<div class="flex md:hidden gap-3 mt-6">
			<button
				id="slider-prev-mobile"
				class="flex-1 inline-flex items-center justify-center gap-2 rounded-full border border-primary/20 text-primary text-sm font-semibold py-2"
			>
				{text.prev}
			</button>
			<button
				id="slider-next-mobile"
				class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-primary text-white text-sm font-semibold py-2"
			>
				{text.next}
			</button>
		</div>
	</div>

	<div class="flex justify-center gap-2 pb-4" id="slider-dots">
		{
			items.map((_, index) => (
				<button
					class="w-3 h-3 rounded-full transition-all duration-300 bg-gray-300"
					data-dot={index}
					aria-label={`${text.goTo} ${index + 1}`}
				/>
			))
		}
	</div>
</section>

<script>
	const track = document.getElementById('slider-track');
	const prevBtn = document.getElementById('slider-prev');
	const nextBtn = document.getElementById('slider-next');
	const prevBtnMobile = document.getElementById('slider-prev-mobile');
	const nextBtnMobile = document.getElementById('slider-next-mobile');
	const dots = document.querySelectorAll('[data-dot]');

	let currentIndex = 0;
	let slidesPerView = 1;

	function getSlidesPerView() {
		if (window.innerWidth >= 1024) return 3;
		if (window.innerWidth >= 768) return 2;
		return 1;
	}

	function updateSlider() {
		if (!track) return;
		slidesPerView = getSlidesPerView();
		const maxIndex = Math.max(0, 5 - slidesPerView);
		currentIndex = Math.min(currentIndex, maxIndex);
		const slideWidth = 100 / slidesPerView;
		track.style.transform = `translateX(-${currentIndex * slideWidth}%)`;

		dots.forEach((dot, i) => {
			if (i === currentIndex) {
				dot.classList.remove('bg-gray-300');
				dot.classList.add('bg-secondary');
			} else {
				dot.classList.remove('bg-secondary');
				dot.classList.add('bg-gray-300');
			}
		});
	}

	function goNext() {
		const maxIndex = Math.max(0, 5 - slidesPerView);
		currentIndex = currentIndex >= maxIndex ? 0 : currentIndex + 1;
		updateSlider();
	}

	function goPrev() {
		const maxIndex = Math.max(0, 5 - slidesPerView);
		currentIndex = currentIndex <= 0 ? maxIndex : currentIndex - 1;
		updateSlider();
	}

	prevBtn?.addEventListener('click', goPrev);
	nextBtn?.addEventListener('click', goNext);
	prevBtnMobile?.addEventListener('click', goPrev);
	nextBtnMobile?.addEventListener('click', goNext);

	dots.forEach((dot) => {
		dot.addEventListener('click', () => {
			currentIndex = parseInt(dot.getAttribute('data-dot') || '0');
			updateSlider();
		});
	});

	window.addEventListener('resize', updateSlider);

	updateSlider();
</script>
