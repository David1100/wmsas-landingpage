---

---

<section class="py-8 lg:py-20 min-h-screen relative">
    <div class="text-center mb-10">
        <h2 class="text-xl md:text-2xl font-semibold text-blue-900">
            Así implementamos tu sistema solar paso a paso
        </h2>
        <p class="text-gray-600">
            Un proceso estructurado en <span class="text-green-500 font-bold"
                >6 etapas</span
            >
        </p>
    </div>

    <div
        id="timeline"
        class="flex justify-center items-center mb-12 flex-wrap"
    >
    </div>
    <div class="flex items-center justify-center gap-10">
        <img src="/images/solar-icon.svg" class="w-40" alt="" id="solar-icon" />
        <div
            class="w-xl bg-white rounded-2xl shadow-lg p-6 relative transition-all duration-500"
            id="card"
        >
            <h3 id="title" class="text-2xl font-bold text-blue-900 mb-2"></h3>

            <p id="desc" class="text-sm text-gray-600 mb-4"></p>

            <hr class="mb-4" />

            <ul id="list" class="space-y-2 mb-6"></ul>

            <div id="progress" class="flex items-center gap-2"></div>
        </div>
        <img src="/images/energia-solar-icon.svg" class="w-40" alt="" />
    </div>
    
    <div id="connector-line" class="absolute pointer-events-none z-10"></div>
</section>

<script>
    const steps = [
        {
            letter: "A",
            title: "ASESORÍA",
            desc: "Evaluación técnica y energética personalizada",
            items: [
                "Análisis de consumo eléctrico",
                "Evaluación de espacio disponible",
                "Revisión de viabilidad técnica",
                "Estimación preliminar de ahorro",
            ],
        },
        {
            letter: "C",
            title: "COTIZACIÓN",
            desc: "Propuesta económica detallada",
            items: [
                "Costos del sistema",
                "Opciones de financiamiento",
                "Retorno de inversión",
            ],
        },
        {
            letter: "C",
            title: "CONTRATACIÓN",
            desc: "Formalización del proyecto",
            items: [
                "Firma de contrato",
                "Definición de tiempos",
                "Inicio del proyecto",
            ],
        },
        {
            letter: "I",
            title: "IMPLEMENTACIÓN",
            desc: "Instalación del sistema",
            items: [
                "Montaje de paneles",
                "Instalación eléctrica",
                "Pruebas del sistema",
            ],
        },
        {
            letter: "O",
            title: "OPERACIÓN",
            desc: "Sistema en funcionamiento",
            items: ["Monitoreo", "Optimización", "Seguimiento"],
        },
        {
            letter: "N",
            title: "NORMALIZACIÓN",
            desc: "Legalización del sistema",
            items: ["Trámites", "Certificaciones", "Conexión a red"],
        },
    ];

    let current = 0;

    const timeline = document.getElementById("timeline");
    const title = document.getElementById("title");
    const desc = document.getElementById("desc");
    const list = document.getElementById("list");
    const progress = document.getElementById("progress");

    function renderTimeline() {
        timeline.innerHTML = "";

        steps.forEach((step, i) => {
            const wrapper = document.createElement("div");
            wrapper.className = "flex items-center cursor-pointer";

            const circleInner = document.createElement("div");
            circleInner.className = "flex items-center justify-center flex-col";

            const circle = document.createElement("div");
            circle.className = `
        w-10 h-10 flex items-center justify-center rounded-full border-1 text-3xl p-6
        ${i === current ? "bg-yellow-300 border-2 border-secondary scale-110 shadow-secondary/50 shadow-xl text-primary" : "bg-white text-blue-900 border-primary"}
        transition-all duration-300
      `;
            circle.innerText = step.letter;
            if (step.letter === 'A') {
                circle.id = 'letter-A';
            }

            circle.onclick = () => {
                current = i;
                render();
            };

            circleInner.appendChild(circle);

            const circleTitle = document.createElement("span");
            circleTitle.className = `block mt-2 text-[9px] font-semibold text-center max-w-16 ${i === current ? "text-primary" : "text-gray-600"}`;
            circleTitle.innerText = step.title;
            circleInner.appendChild(circleTitle);

            wrapper.appendChild(circleInner);

            if (i < steps.length - 1) {
                const connector = document.createElement("div");
                connector.className = "flex items-center -mt-4";

                const lineLeft = document.createElement("div");
                lineLeft.className = "w-6 h-[2px] bg-primary";
                
                const arrowIcon = document.createElement("img");
                arrowIcon.src = "/images/energy-icon.svg";
                arrowIcon.className = "w-5 h-5 text-primary mx-1";
                arrowIcon.alt = "";

                const lineRight = document.createElement("div");
                lineRight.className = "w-6 h-[2px] bg-primary";

                connector.appendChild(lineLeft);
                connector.appendChild(arrowIcon);
                connector.appendChild(lineRight);
                wrapper.appendChild(connector);
            }

            timeline.appendChild(wrapper);
        });
    }

    function renderContent() {
        const step = steps[current];

        title.innerText = step.title;
        desc.innerText = step.desc;

        list.innerHTML = "";
        step.items.forEach((item) => {
            const li = document.createElement("li");
            li.className =
                "flex items-center gap-2 opacity-0 translate-y-2 transition-all duration-500";

            li.innerHTML = `
        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
        ${item}
      `;

            list.appendChild(li);

            setTimeout(() => {
                li.classList.remove("opacity-0", "translate-y-2");
            }, 100);
        });
    }

    function renderProgress() {
        progress.innerHTML = "";

        steps.forEach((_, i) => {
            const bar = document.createElement("div");
            bar.className = `
        h-2 flex-1 rounded-full transition-all duration-500
        ${i <= current ? "bg-yellow-400" : "bg-gray-300"}
      `;
           progress.appendChild(bar);
        });
    }

    function render() {
        renderTimeline();
        renderContent();
        renderProgress();
        setTimeout(drawConnector, 0);
    }

    function drawConnector() {
        const solarIcon = document.getElementById('solar-icon');
        const letterA = document.getElementById('letter-A');
        
        if (!solarIcon || !letterA) return;
        
        const iconRect = solarIcon.getBoundingClientRect();
        const letterRect = letterA.getBoundingClientRect();
        
        const startX = iconRect.right;
        const startY = iconRect.top + iconRect.height / 2;
        const endX = letterRect.left;
        const endY = letterRect.top + letterRect.height / 2;
        
        const midX = (startX + endX) / 2;
        const cornerY = endY;
        
        const connector = document.getElementById('connector-line');
        connector.style.left = '0';
        connector.style.top = '0';
        connector.style.width = '100%';
        connector.style.height = '100%';
        connector.style.position = 'fixed';
        connector.style.pointerEvents = 'none';
        connector.style.zIndex = '10';
        
        connector.innerHTML = `
            <svg width="100%" height="100%" style="position:absolute;top:0;left:0;">
                <path d="M ${startX} ${startY} L ${startX} ${cornerY} L ${endX} ${cornerY}" 
                      stroke="var(--primary)" stroke-width="2" fill="none"/>
            </svg>
            <div style="position:absolute; left:${midX}px; top:${cornerY}px; transform:translate(-50%,-50%); 
                        background:white; padding:4px; border-radius:50%;">
                <img src="/images/energy-icon.svg" style="width:20px;height:20px;" />
            </div>
        `;
    }

    window.addEventListener('resize', drawConnector);
    render();
</script>
