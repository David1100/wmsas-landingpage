---
const steps = [
	{
		phase: "A",
		title: "Asesoría",
		description:
			"Evaluamos consumo, infraestructura y normativa para definir alcance real",
		points: [
			"Levantamiento energético",
			"Inspección en sitio",
			"Modelado inicial",
		],
	},
	{
		phase: "C",
		title: "Cotización",
		description: "Escogemos tecnología y planteamos escenarios financieros",
		points: [
			"Diseño 3D + simulación",
			"CapEx / OpEx",
			"Opciones de financiamiento",
		],
	},
	{
		phase: "C",
		title: "Contratación",
		description: "Formalizamos alcance, garantías y cronograma",
		points: ["Firma digital", "Cronograma ejecutivo", "Gestión documental"],
	},
	{
		phase: "I",
		title: "Implementación",
		description: "Instalamos, probamos y dejamos operando el sistema",
		points: ["Obra civil y eléctrica", "Interconexión", "Pruebas RETIE"],
	},
	{
		phase: "O",
		title: "Operación",
		description: "Monitoreamos en tiempo real y ajustamos el performance",
		points: ["Plataforma 24/7", "Alertas", "Mantenimiento"],
	},
	{
		phase: "N",
		title: "Normalización",
		description: "Gestionamos certificaciones, conexión a red y garantías",
		points: [
			"Trámites con comercializador",
			"Certificados RETIE",
			"Capacitación",
		],
	},
];
---

<section id="accion" class="py-12 lg:py-24 relative overflow-hidden">
	<div
		class="absolute inset-0 bg-gradient-to-b from-white via-white to-transparent"
	>
	</div>
	<div class="max-w-6xl mx-auto px-4 lg:px-8 relative space-y-12">
		<div class="text-center" data-reveal>
			<p class="text-xs uppercase tracking-[0.5em] text-primary/60">
				Proceso WM SAS
			</p>
			<h2 class="text-3xl sm:text-4xl font-display text-primary">
				Así implementamos tu sistema solar paso a paso
			</h2>
			<p class="text-sm text-primary/70">
				Un proceso estructurado en <span
					class="text-secondary font-semibold">6 etapas</span
				>
			</p>
		</div>

		<div class="accion-stage relative space-y-10">
			<div class="flex flex-col gap-6" data-reveal>
				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-4 md:gap-6 lg:gap-10">
						<div class="accion-terminal" data-terminal="start">
							<div class="accion-terminal__icon">
								<img
									src="/images/solar-icon.svg"
									alt="Icono solar"
									class="w-16"
								/>
							</div>
							<span class="accion-terminal__label">Inicio</span>
						</div>
						<div
							class="flex-1 min-w-0 lg:max-w-4xl mx-auto relative"
							id="accion-track"
						>
							<div
								class="track-base h-2 bg-primary/10 rounded-full w-full"
							>
							</div>
							<div
								class="h-2 bg-secondary rounded-full transition-all duration-700"
								id="accion-progress"
								style="width:0%"
							>
							</div>
							<div
								class="absolute inset-x-0 top-1/2 flex justify-between"
								id="accion-steps"
							>
								{
									steps.map((step, index) => (
										<button
											type="button"
											class="accion-node"
											data-step={index}
										>
											<span>{step.phase}</span>
											<small>{step.title}</small>
										</button>
									))
								}
							</div>
						</div>
						<div class="accion-terminal" data-terminal="end">
							<div class="accion-terminal__icon">
								<img
									src="/images/energia-solar-icon.svg"
									alt="Casa WM"
									class="w-16"
								/>
							</div>
							<span class="accion-terminal__label"
								>Normalización</span
							>
						</div>
					</div>
				</div>
			</div>

		<div
			class="glass-panel rounded-[2rem] bg-white/90 p-6 sm:p-8 space-y-6"
			data-reveal
			id="accion-card"
		>
			<div
				class="flex flex-col sm:flex-row sm:items-center gap-2 justify-between"
			>
				<p
					class="text-xs uppercase tracking-[0.4em] text-primary/60"
				>
					Etapa <span id="accion-step-number">1</span> / 6
				</p>
				<span class="text-sm text-primary/60"
					>Duración promedio: 45 días</span
				>
			</div>
			<h3
				class="text-2xl sm:text-3xl font-display text-primary"
				id="accion-title"
			>
				Asesoría
			</h3>
			<p class="text-base text-primary/70" id="accion-description">
				Evaluación técnica y energética personalizada antes de
				cualquier decisión.
			</p>
			<ul
				class="space-y-3 text-sm text-primary/80"
				id="accion-points"
			>
			</ul>
			<div class="flex items-center gap-2" id="accion-progress-dots">
			</div>
			<button
				id="accion-next"
				class="ml-auto inline-flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-primary text-white font-semibold text-sm w-full sm:w-auto"
			>
				Siguiente etapa
				<span>→</span>
			</button>
		</div>
		</div>
	</div>
</section>

<script
	type="application/json"
	id="accion-data"
	set:html={JSON.stringify(steps)}
/>
<style>
	.accion-stage {
		position: relative;
		--accion-track-offset: 2.4rem;
	}

	.accion-terminal {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding-bottom: 2.2rem;
	}

	.accion-terminal__icon {
		width: 7rem;
		height: 7rem;
		border-radius: 999px;
		border: 2px solid var(--color-primary);
		background: #fff;
		box-shadow: 0 30px 70px -40px rgba(17, 24, 39, 0.6);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		animation: float-y 10s ease-in-out infinite;
		transition:
			transform 0.4s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}

	.accion-terminal__icon.is-complete {
		transform: scale(1.08);
		border-color: var(--color-secondary);
		box-shadow: 0 25px 60px -30px rgba(208, 216, 23, 0.5);
	}

	.accion-terminal__label {
		position: absolute;
		top: calc(100% - 0.4rem);
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.65rem;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: rgba(57, 60, 122, 0.7);
		white-space: nowrap;
	}

	.accion-terminal[data-terminal="start"]::after,
	.accion-terminal[data-terminal="end"]::after {
		display: none;
	}

	.accion-node {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		text-transform: uppercase;
		font-weight: 600;
		font-size: 0.75rem;
		color: rgba(57, 60, 122, 0.55);
		transition:
			transform 0.2s ease,
			color 0.2s ease;
		position: relative;
		z-index: 2;
	}

	.accion-node span {
		display: inline-flex;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		align-items: center;
		justify-content: center;
		background: white;
		border: 2px solid rgba(57, 60, 122, 0.2);
		font-size: 1.2rem;
		color: var(--color-primary);
		box-shadow: 0 10px 30px -20px rgba(0, 0, 0, 0.6);
	}

	.accion-node small {
		font-size: 0.6rem;
		letter-spacing: 0.2em;
	}

	.accion-node.active {
		color: var(--color-primary);
		transform: translateY(-8px);
	}

	.accion-node.active span {
		border-color: var(--color-secondary);
		box-shadow: 0 15px 40px -20px rgba(208, 216, 23, 0.8);
		color: var(--color-secondary);
	}

	#accion-progress-dots div {
		flex: 1;
		height: 0.5rem;
		border-radius: 999px;
		background: rgba(57, 60, 122, 0.15);
		transition: background 0.3s ease;
	}

	#accion-progress-dots div.active {
		background: var(--color-secondary);
	}

	#accion-track {
		position: relative;
		min-height: calc(4.5rem + var(--accion-track-offset));
		padding: calc(2.5rem + var(--accion-track-offset)) 0 1.5rem;
	}

	#accion-track .track-base,
	#accion-progress {
		position: absolute;
		left: 0;
		right: 0;
		top: calc(50% + var(--accion-track-offset));
		transform: translateY(-50%);
		height: 0.35rem;
		pointer-events: none;
		z-index: 0;
	}

	#accion-progress {
		z-index: 1;
	}

	#accion-steps {
		transform: translateY(calc(-50% - var(--accion-track-offset)));
		z-index: 2;
	}

	@media (max-width: 768px) {
		.accion-terminal__label {
			font-size: 5px;
		}
		.accion-terminal__icon {
			width: 5.2rem;
			height: 5.2rem;
		}
		#accion-track {
			padding: 1.5rem 0 0;
		}
		#accion-track .track-base,
		#accion-progress {
			display: none;
		}
		#accion-steps {
			position: static;
			transform: none;
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.85rem;
			justify-items: center;
		}
		.accion-node span {
			width: 2.5rem;
			height: 2.5rem;
			font-size: 1rem;
		}
		.accion-node small {
			font-size: 0.28rem;
			letter-spacing: 0.16em;
			text-align: center;
		}
	}
</style>

<script is:inline>
	function initAccionTimeline() {
		const dataTag = document.getElementById("accion-data");
		let stepsData = [];
		try {
			stepsData = dataTag?.textContent
				? JSON.parse(dataTag.textContent)
				: [];
		} catch (error) {
			console.error("No se pudo leer el flujo ACCION", error);
			return;
		}
		if (!Array.isArray(stepsData) || !stepsData.length) return;

		let accionCurrent = 0;
		const cardTitle = document.getElementById("accion-title");
		const cardDesc = document.getElementById("accion-description");
		const cardList = document.getElementById("accion-points");
		const stepNumber = document.getElementById("accion-step-number");
		const dotContainer = document.getElementById("accion-progress-dots");
		const progressLine = document.getElementById("accion-progress");
		const nodes = document.querySelectorAll(".accion-node");
		const nextButton = document.getElementById("accion-next");
		const terminalStart = document.querySelector(
			'[data-terminal="start"] .accion-terminal__icon',
		);
		const terminalEnd = document.querySelector(
			'[data-terminal="end"] .accion-terminal__icon',
		);
		let lastPercent = 0;
		let currentAnimation = null;
		const progressColors = [
			"var(--color-secondary)",
			"#8da8ff",
			"#7cc3ff",
			"#6fd8d5",
			"#5fd99f",
			"#f3b86b",
		];

		function renderDots() {
			dotContainer.innerHTML = "";
			stepsData.forEach((_, index) => {
				const segment = document.createElement("div");
				segment.className = index <= accionCurrent ? "active" : "";
				dotContainer.appendChild(segment);
			});
		}

		function animateProgress(nextPercent) {
			const color =
				progressColors[accionCurrent] || "var(--color-secondary)";
			progressLine.style.background = color;
			if (!progressLine) return;
			if (currentAnimation) currentAnimation.cancel();
			if (progressLine.animate) {
				currentAnimation = progressLine.animate(
					[
						{ width: `${lastPercent}%` },
						{ width: `${nextPercent}%` },
					],
					{
						duration: 900,
						easing: "cubic-bezier(0.16, 1, 0.3, 1)",
						fill: "forwards",
					},
				);
				currentAnimation.onfinish = () => {
					progressLine.style.width = `${nextPercent}%`;
					lastPercent = nextPercent;
					currentAnimation = null;
				};
			} else {
				progressLine.style.transition =
					"width 0.9s cubic-bezier(0.16, 1, 0.3, 1)";
				progressLine.style.width = `${nextPercent}%`;
				lastPercent = nextPercent;
			}
		}

		function renderStep() {
			const step = stepsData[accionCurrent];
			stepNumber.textContent = accionCurrent + 1;
			cardTitle.textContent = step.title;
			cardDesc.textContent = step.description;
			cardList.innerHTML = "";
			step.points.forEach((point) => {
				const item = document.createElement("li");
				item.className = "flex items-center gap-3";
				item.innerHTML = `<span class="w-3 h-3 rounded-full bg-secondary"></span>${point}`;
				cardList.appendChild(item);
			});
			nodes.forEach((node, index) => {
				node.classList.toggle("active", index === accionCurrent);
			});
			if (accionCurrent === stepsData.length - 1) {
				terminalEnd?.classList.add("is-complete");
			} else {
				terminalEnd?.classList.remove("is-complete");
			}
			const progressPercent =
				(accionCurrent / (stepsData.length - 1)) * 100;
			animateProgress(progressPercent);
			renderDots();
		}

		nodes.forEach((node) => {
			node.addEventListener("click", () => {
				accionCurrent = parseInt(
					node.getAttribute("data-step") || "0",
					10,
				);
				renderStep();
			});
		});

		nextButton?.addEventListener("click", () => {
			accionCurrent = (accionCurrent + 1) % stepsData.length;
			renderStep();
		});

		renderDots();
		progressLine.style.width = "0%";
		lastPercent = 0;
		renderStep();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initAccionTimeline, {
			once: true,
		});
	} else {
		initAccionTimeline();
	}
</script>

