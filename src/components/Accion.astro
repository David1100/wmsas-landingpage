---
const steps = [
	{
		phase: "A",
		title: "Asesoría",
		description: "Evaluamos consumo, infraestructura y normativa para definir alcance real",
		points: ["Levantamiento energético", "Inspección en sitio", "Modelado inicial"],
	},
	{
		phase: "C",
		title: "Cotización",
		description: "Escogemos tecnología y planteamos escenarios financieros",
		points: ["Diseño 3D + simulación", "CapEx / OpEx", "Opciones de financiamiento"],
	},
	{
		phase: "C",
		title: "Contratación",
		description: "Formalizamos alcance, garantías y cronograma",
		points: ["Firma digital", "Cronograma ejecutivo", "Gestión documental"],
	},
	{
		phase: "I",
		title: "Implementación",
		description: "Instalamos, probamos y dejamos operando el sistema",
		points: ["Obra civil y eléctrica", "Interconexión", "Pruebas RETIE"],
	},
	{
		phase: "O",
		title: "Operación",
		description: "Monitoreamos en tiempo real y ajustamos el performance",
		points: ["Plataforma 24/7", "Alertas", "Mantenimiento"],
	},
	{
		phase: "N",
		title: "Normalización",
		description: "Gestionamos certificaciones, conexión a red y garantías",
		points: ["Trámites con comercializador", "Certificados RETIE", "Capacitación"],
	},
];
---

<section id="accion" class="py-12 lg:py-24 relative overflow-hidden">
	<div class="absolute inset-0 bg-gradient-to-b from-white via-white to-transparent"></div>
	<div class="max-w-6xl mx-auto px-4 lg:px-8 relative" data-reveal>
		<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="bg-primary text-white rounded-[2rem] p-8 space-y-6 shadow-[0_50px_80px_-60px_rgba(10,15,41,1)]" data-reveal="left">
				<p class="text-xs uppercase tracking-[0.5em] text-secondary/80">Metodología WM</p>
				<h2 class="text-3xl lg:text-4xl font-display leading-tight">
					Así implementamos tu sistema solar paso a paso
				</h2>
				<p class="text-sm text-white/80">
					Seis etapas claras, responsables y auditables. Nos encargamos de ingeniería, trámites y acompañamiento para que solo te concentres en ver tu factura bajar.
				</p>
				<div class="flex flex-wrap gap-4">
					<div class="px-4 py-3 rounded-2xl bg-white/10">
						<p class="text-xs uppercase tracking-[0.4em] text-white/60">Duración promedio</p>
						<p class="text-2xl font-display">45 días</p>
					</div>
					<div class="px-4 py-3 rounded-2xl bg-white/10">
						<p class="text-xs uppercase tracking-[0.4em] text-white/60">Equipo dedicado</p>
						<p class="text-2xl font-display">+8 especialistas</p>
					</div>
				</div>
				<a href="https://wa.me/573001234567" class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-secondary text-primary font-semibold text-sm uppercase tracking-wide">
					Hablar con un ingeniero
					<span class="text-lg">→</span>
				</a>
			</div>

			<div class="overflow-hidden" data-reveal="right" style="--reveal-delay:160ms">
				<div class="overflow-x-auto pb-6" aria-label="Línea de tiempo WM">
					<ol class="flex gap-6 min-w-max">
					{steps.map((step, index) => (
						<li class="relative flex-1 min-w-[240px]" data-reveal style={`--reveal-delay:${index * 90}ms`}>
								<div class="h-1 bg-primary/10 rounded-full mb-6 overflow-hidden">
									<div class="h-full bg-gradient-to-r from-secondary to-transparent" style={`width: ${(index + 1) * (100 / steps.length)}%`}></div>
								</div>
								<div class="rounded-[1.7rem] border border-primary/10 bg-white/90 p-6 shadow-[0_20px_40px_-40px_rgba(10,15,41,1)]">
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-display text-lg">
											{step.phase}
										</div>
										<p class="text-xs uppercase tracking-[0.4em] text-primary/50">Etapa {index + 1}</p>
									</div>
									<h3 class="text-xl font-display text-primary mt-4">{step.title}</h3>
									<p class="text-sm text-primary/70">{step.description}</p>
									<ul class="mt-4 space-y-2 text-sm text-primary/80">
										{step.points.map((point) => (
											<li class="flex items-center gap-2">
												<span class="w-2 h-2 rounded-full bg-secondary"></span>
												{point}
											</li>
										))}
									</ul>
								</div>
							</li>
						))}
					</ol>
				</div>
				<p class="text-xs text-primary/60 text-center">Documentamos cada fase y compartimos avances en un panel digital.</p>
			</div>
		</div>
	</div>
</section>
