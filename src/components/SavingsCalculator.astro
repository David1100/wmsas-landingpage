---
const { lang = 'es' } = Astro.props;

const copy = {
	es: {
		leftStep: 'configura tu proyecto',
		leftTitle: 'Simulador de ahorro WM SAS',
		leftSubtitle: 'Cuéntanos dónde consumes energía y te mostramos tu retorno estimado al instante.',
		addressLabel: 'Dirección o municipio',
		addressPlaceholder: 'Ej. Barrio El Prado, Barranquilla',
		propertyLabel: 'Tipo de propiedad',
		propertyTypes: [
			{ label: 'Hogar', value: 'hogar' },
			{ label: 'Empresa', value: 'empresa' },
			{ label: 'Agro', value: 'agro' },
		],
		billLabel: 'Factura mensual (COP)',
		consumptionLabel: 'Consumo mensual (kWh)',
		irradianceLabel: 'Potencial solar',
		irradianceOptions: [
			{ label: 'Costa / Alta radiación', value: 'alta' },
			{ label: 'Andina / Media', value: 'media' },
			{ label: 'Interior / Baja', value: 'baja' },
		],
		disclaimer: '*Estimación preliminar. Validamos potencia disponible y requisitos RETIE durante la visita técnica.',
		rightStep: 'resultado',
		rightTitle: 'Tu proyección energética',
		rightSubtitle: 'Actualizamos la simulación en tiempo real.',
		savingsCard: 'Ahorro proyectado',
		savingsNote: 'Comparado con tu factura actual.',
		investmentLabel: 'Inversión estimada',
		investmentNote: 'Incluye ingeniería y montaje WM SAS.',
		retornoLabel: 'Retorno',
		retornoNote: 'Depende de tu perfil de carga.',
		defaultSummary: 'Hogar mediterráneo: reemplazamos el 78% de tu consumo con un arreglo de 6.2 kWp. Incluye monitoreo 24/7.',
		planLabels: {
			hogar: 'Plan residencial solar+',
			empresa: 'Plan corporativo solar pro',
			agro: 'Plan agro solar adaptativo',
		},
		planSummaries: {
			hogar: 'Reemplazamos hasta el 80% de tu consumo con un arreglo compacto.',
			empresa: 'Sistema trifásico escalable con monitoreo 24/7 y soporte prioritario.',
			agro: 'Diseño resistente a ambientes rurales, incluye microinversores.',
		},
		serviceBadge: 'Visita técnica en 48h',
		cta: 'Solicitar asesoría con ingeniero',
		ctaNote: 'Prometemos responder en menos de 24 horas hábiles.',
		tierNote: 'Comparado con tu factura actual.',
	},
	en: {
		leftStep: 'set up your project',
		leftTitle: 'WM SAS savings simulator',
		leftSubtitle: 'Tell us where you consume energy and we will estimate your ROI instantly.',
		addressLabel: 'Address or city',
		addressPlaceholder: 'E.g. El Prado neighborhood, Barranquilla',
		propertyLabel: 'Property type',
		propertyTypes: [
			{ label: 'Home', value: 'hogar' },
			{ label: 'Business', value: 'empresa' },
			{ label: 'Agro', value: 'agro' },
		],
		billLabel: 'Monthly bill (COP)',
		consumptionLabel: 'Monthly consumption (kWh)',
		irradianceLabel: 'Solar potential',
		irradianceOptions: [
			{ label: 'Coast / High irradiance', value: 'alta' },
			{ label: 'Andean / Medium', value: 'media' },
			{ label: 'Interior / Low', value: 'baja' },
		],
		disclaimer: '*Preliminary estimation. We validate available capacity and RETIE requirements during the site visit.',
		rightStep: 'results',
		rightTitle: 'Your energy projection',
		rightSubtitle: 'We update the simulation in real time.',
		savingsCard: 'Projected savings',
		savingsNote: 'Compared with your current bill.',
		investmentLabel: 'Estimated investment',
		investmentNote: 'Includes WM SAS engineering and installation.',
		retornoLabel: 'Payback',
		retornoNote: 'Depends on your load profile.',
		defaultSummary: 'Mediterranean home: we offset 78% of your use with a 6.2 kWp array plus 24/7 monitoring.',
		planLabels: {
			hogar: 'Residential solar+ plan',
			empresa: 'Corporate solar pro plan',
			agro: 'Agro adaptive solar plan',
		},
		planSummaries: {
			hogar: 'We offset up to 80% of your demand with a compact array.',
			empresa: 'Scalable three-phase system with 24/7 monitoring and priority support.',
			agro: 'Rugged design for rural settings, includes microinverters.',
		},
		serviceBadge: 'Site visit within 48h',
		cta: 'Request an engineer consult',
		ctaNote: 'We reply in under 24 business hours.',
		tierNote: 'Compared with your current bill.',
	},
};

const propertyTypes = copy[lang].propertyTypes;
const irradiance = copy[lang].irradianceOptions;
const text = copy[lang];
---
---


<div class="max-w-5xl mx-auto" data-reveal>
	<div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
		<div class="bg-white/95 rounded-[1.8rem] p-6 sm:p-8 shadow-[0_40px_80px_-60px_rgba(12,21,39,0.9)] border border-white/60" data-reveal="left">
			<div class="flex items-center gap-3 text-xs uppercase tracking-[0.4em] text-primary/60">
				<span class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-semibold">01</span>
				<span>{text.leftStep}</span>
			</div>
			<h2 class="text-2xl sm:text-3xl font-display text-primary mt-4">{text.leftTitle}</h2>
			<p class="text-sm text-primary/70 mt-2">{text.leftSubtitle}</p>

			<div class="mt-8 space-y-6">
				<label class="block text-sm font-semibold text-primary">{text.addressLabel}</label>
				<input
					id="input-address"
					type="text"
					placeholder={text.addressPlaceholder}
					class="w-full px-4 py-3 rounded-xl bg-primary/5 border border-primary/15 focus:border-secondary focus:ring-2 focus:ring-secondary/40"
				/>

				<div>
					<p class="text-sm font-semibold text-primary mb-3">{text.propertyLabel}</p>
					<div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
						{propertyTypes.map((type) => (
							<button
								type="button"
								class="step-chip"
								data-property={type.value}
							>
								{type.label}
							</button>
						))}
					</div>
				</div>

				<div class="space-y-3">
					<div class="flex items-center justify-between text-sm text-primary/70">
						<label for="bill-range" class="font-semibold text-primary">{text.billLabel}</label>
						<span id="bill-output" class="font-display text-lg text-primary">$600.000</span>
					</div>
					<input id="bill-range" type="range" min="200000" max="3000000" step="50000" value="600000" class="range-input" />
				</div>

				<div class="space-y-3">
					<div class="flex items-center justify-between text-sm text-primary/70">
						<label for="consumption-range" class="font-semibold text-primary">{text.consumptionLabel}</label>
						<span id="consumption-output" class="font-display text-lg text-primary">420 kWh</span>
					</div>
					<input id="consumption-range" type="range" min="150" max="2500" step="10" value="420" class="range-input" />
				</div>

				<div>
					<p class="text-sm font-semibold text-primary mb-3">{text.irradianceLabel}</p>
					<div class="grid gap-2 sm:grid-cols-3">
						{irradiance.map((item) => (
							<button
								type="button"
								class="step-chip"
								data-irradiance={item.value}
							>
								{item.label}
							</button>
						))}
					</div>
				</div>
			</div>

			<p class="text-xs text-primary/50 mt-8">
				{text.disclaimer}
			</p>
		</div>

		<div class="glass-panel rounded-[1.8rem] p-6 sm:p-8 bg-white/80" data-reveal="right" style="--reveal-delay:120ms">
			<div class="flex items-center gap-3 text-xs uppercase tracking-[0.4em] text-primary/60">
				<span class="w-8 h-8 rounded-full bg-secondary text-primary flex items-center justify-center font-semibold">02</span>
				<span>{text.rightStep}</span>
			</div>
			<h3 class="text-2xl font-display text-primary mt-4">{text.rightTitle}</h3>
			<p class="text-sm text-primary/70">{text.rightSubtitle}</p>

			<div class="mt-8 space-y-6">
				<div class="bg-primary text-white rounded-2xl p-5 space-y-2">
					<p class="text-xs uppercase tracking-[0.4em] text-white/70">{text.savingsCard}</p>
					<p data-result-ahorro class="text-4xl font-display">78%</p>
					<div class="w-full h-3 bg-white/20 rounded-full overflow-hidden">
						<div data-progress class="h-full bg-secondary" style="width: 78%"></div>
					</div>
					<p class="text-sm text-white/80">{text.savingsNote}</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					<div class="rounded-xl border border-primary/10 p-4">
						<p class="text-xs uppercase tracking-[0.3em] text-primary/50">{text.investmentLabel}</p>
						<p data-result-inversion class="text-2xl font-display text-primary">$18.5 M</p>
						<p class="text-xs text-primary/50">{text.investmentNote}</p>
					</div>
					<div class="rounded-xl border border-primary/10 p-4">
						<p class="text-xs uppercase tracking-[0.3em] text-primary/50">{text.retornoLabel}</p>
						<p data-result-retorno class="text-2xl font-display text-primary">36 meses</p>
						<p class="text-xs text-primary/50">{text.retornoNote}</p>
					</div>
				</div>

				<div class="rounded-2xl bg-primary/5 border border-primary/10 p-4">
					<p class="text-sm text-primary/70" data-summary>
						{text.planSummaries.hogar}
					</p>
				</div>

				<div class="flex flex-wrap gap-3">
					<div class="px-4 py-2 rounded-full bg-secondary/20 text-xs font-semibold text-primary" data-tier>{text.planLabels.hogar}</div>
					<div class="px-4 py-2 rounded-full bg-primary text-white text-xs font-semibold">{text.serviceBadge}</div>
				</div>
			</div>

			<div class="mt-10 flex flex-col gap-3">
				<a
					href="https://wa.me/573001234567"
					target="_blank"
					rel="noreferrer"
					class="w-full inline-flex items-center justify-center gap-3 px-6 py-3 rounded-full bg-secondary text-primary font-semibold uppercase tracking-wide text-sm"
				>
					{text.cta}
				</a>
				<p class="text-xs text-primary/50 text-center">{text.ctaNote}</p>
			</div>
		</div>
	</div>
</div>

<style>
	.range-input {
		width: 100%;
		height: 0.5rem;
		border-radius: 999px;
		background: rgba(20, 26, 54, 0.08);
		appearance: none;
	}

	.range-input:focus {
		outline: none;
	}

	.range-input::-webkit-slider-thumb {
		appearance: none;
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 999px;
		background: var(--secondary);
		border: 2px solid #fff;
		box-shadow: 0 10px 20px rgba(20, 26, 54, 0.25);
	}

	.range-input::-moz-range-thumb {
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 999px;
		background: var(--secondary);
		border: 2px solid #fff;
		box-shadow: 0 10px 20px rgba(20, 26, 54, 0.25);
	}

	.step-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		text-transform: uppercase;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		padding: 0.7rem 0.5rem;
		border-radius: 1rem;
		border: 1px solid rgba(20, 26, 54, 0.15);
		color: rgba(20, 26, 54, 0.6);
		background: rgba(20, 26, 54, 0.04);
		transition: background 0.2s ease, color 0.2s ease, border 0.2s ease;
	}

	.step-chip.active {
		background: var(--primary);
		color: #fff;
		border-color: var(--primary);
	}
</style>

<script is:inline>
    const planLabels = ${JSON.stringify(text.planLabels)};
    const planSummaries = ${JSON.stringify(text.planSummaries)};

    const state = {
        property: "hogar",
        irradiance: "media",
        bill: 600000,
        consumption: 420,
    };

    const propertyButtons = document.querySelectorAll('[data-property]');
    const irradianceButtons = document.querySelectorAll('[data-irradiance]');
    const billInput = document.getElementById('bill-range');
    const consumptionInput = document.getElementById('consumption-range');
    const billOutput = document.getElementById('bill-output');
    const consumptionOutput = document.getElementById('consumption-output');
    const ahorroNode = document.querySelector('[data-result-ahorro]');
    const progressBar = document.querySelector('[data-progress]');
    const inversionNode = document.querySelector('[data-result-inversion]');
    const retornoNode = document.querySelector('[data-result-retorno]');
    const summaryNode = document.querySelector('[data-summary]');
    const tierNode = document.querySelector('[data-tier]');

    function activateButtons(group, valueKey, newValue) {
        group.forEach((btn) => {
            const value = btn.getAttribute(valueKey);
            if (value === newValue) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });
    }

    function currencyFormat(value) {
        return new Intl.NumberFormat('es-CO', {
            style: 'currency',
            currency: 'COP',
            maximumFractionDigits: 0,
        }).format(value);
    }

    function updateProjection() {
        const irradianceBoost = state.irradiance === 'alta' ? 1.08 : state.irradiance === 'media' ? 1 : 0.85;
        const propertyBoost = state.property === 'empresa' ? 1.2 : state.property === 'agro' ? 1.1 : 1;
        const potential = Math.min(92, Math.round((state.consumption / 8) * irradianceBoost));
        const ahorro = Math.min(95, Math.max(40, Math.round((potential / 2) * propertyBoost)));
        const inversion = Math.round((state.bill * 18) / 100000) / 10; // aproximación en millones
        const retorno = Math.max(18, Math.round((state.bill / 200000) * (state.property === 'empresa' ? 24 : 30)));

        ahorroNode.textContent = `${ahorro}%`;
        progressBar.style.width = `${ahorro}%`;
        inversionNode.textContent = `$${inversion.toFixed(1)} M`;
        retornoNode.textContent = `${retorno} meses`;

        const tierLabel = planLabels[state.property] || planLabels.hogar;
        tierNode.textContent = tierLabel;

        const summary = planSummaries[state.property] || planSummaries.hogar;
        summaryNode.textContent = summary;

        billOutput.textContent = currencyFormat(state.bill);
        consumptionOutput.textContent = `${state.consumption} kWh`;
    }

    propertyButtons.forEach((button) => {
        button.addEventListener('click', () => {
            state.property = button.getAttribute('data-property') || 'hogar';
            activateButtons(propertyButtons, 'data-property', state.property);
            updateProjection();
        });
    });

    irradianceButtons.forEach((button) => {
        button.addEventListener('click', () => {
            state.irradiance = button.getAttribute('data-irradiance') || 'media';
            activateButtons(irradianceButtons, 'data-irradiance', state.irradiance);
            updateProjection();
        });
    });

    billInput?.addEventListener('input', () => {
        state.bill = parseInt(billInput.value, 10);
        updateProjection();
    });

    consumptionInput?.addEventListener('input', () => {
        state.consumption = parseInt(consumptionInput.value, 10);
        updateProjection();
    });

    activateButtons(propertyButtons, 'data-property', state.property);
    activateButtons(irradianceButtons, 'data-irradiance', state.irradiance);
    updateProjection();
</script>
