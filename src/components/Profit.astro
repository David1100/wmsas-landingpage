---
import { Icon } from "astro-icon/components";

const items = [
    {
        icon: "ahorrar-dinero-icon",
        title: "ahorro inmediato",
        description1: "Reduce tu factura mensual.",
        description2: "Disminuye tu pago de energía",
        button: "Hasta un 100% menos",
    },
    {
        icon: "ventas-icon",
        title: "rol garantizado",
        description1: "Recupera tu inversion con ahorro",
        description2: "energetico proyectado y sostenido.",
        button: "2 - 5 años",
    },
    {
        icon: "verificado-icon",
        title: "protección contra alzas",
        description1: "Disminuye tu exposición a",
        description2: "futuros incrementos tarifarios",
        button: "Proyecto financiera a largo plazo",
    },
    {
        icon: "tecnologia-icon",
        title: "tecnologia",
        description1: "Equipos certificados con bajo",
        description2: "mantenimiento requerido",
        button: "Componentes TIER 1 certificados",
    },
    {
        icon: "hogar-icon",
        title: "valoriza tu inmueble",
        description1: "Incrementa el atractivo y valor",
        description2: "comercial de tu propiedad",
        button: "Hasta +10% valor",
    },
    {
        icon: "hojas-icon",
        title: "reduce impacto ambiental",
        description1: "Reducción de la huella de carbono.",
        description2: "Genera energia limpia",
        button: "Hasta -10% emisiones C02",
    },
];
---

<section class="h-screen py-12 flex flex-col justify-center items-center">
    <h1 class="text-6xl text-secondary font-bold uppercase">beneficios</h1>
    <p class="text-sm font-semibold">
        Lo que cambias cuando tomas control energetico
    </p>
    <div class="grid grid-cols-3 gap-8 py-12">
        {
            items.map((item, index) => (
                <div class="w-md bg-white rounded-3xl px-8 py-4 shadow-[0_10px_40px_-15px_rgba(0,0,0,0.3)] border border-gray-100 hover:scale-105 transition-all">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="bg-primary p-2 rounded-lg flex items-center justify-center shrink-0">
                            <Icon name={item.icon} class={'text-white text-4xl'}/>
                        </div>

                        <h2 class="text-[#C5D33A] font-semibold text-2xl leading-tight uppercase tracking-tight">
                            {item.title.split(" ")[0]}
                            <br />
                            {item.title.split(" ")[1] +' '+ item.title.split(" ")[2]}
                        </h2>
                    </div>

                    <div class="mb-5">
                        <p class="text-gray-400 font-semibold text-xl leading-snug">
                            {item.description1}
                        </p>
                        <p class="text-gray-400 font-semibold text-xl leading-snug">
                            {item.description2}
                        </p>
                    </div>

                    <div class="bg-primary py-2 px-6 rounded-lg text-center">
                        <button class="text-white font-bold text-lg">
                            {item.button}
                        </button>
                    </div>
                </div>
            ))
        }
    </div>
</section>
