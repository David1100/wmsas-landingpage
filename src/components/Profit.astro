---
import { Icon } from "astro-icon/components";

const items = [
	{
		icon: "ahorrar-dinero-icon",
		title: "Ahorro inmediato",
		copy: "Reduce tu factura desde el primer mes gracias al autoconsumo sincronizado",
		metric: "Hasta 100% menos",
		accent: "from-secondary/50",
	},
	{
		icon: "ventas-icon",
		title: "ROI garantizado",
		copy: "Recupera tu inversión en 24 a 48 meses con contratos de energía estabilizada",
		metric: "ROI 2-4 años",
		accent: "from-primary/40",
	},
	{
		icon: "verificado-icon",
		title: "Escudo tarifario",
		copy: "Protege tu operación ante incrementos inesperados y apagones",
		metric: "+15 años cobertura",
		accent: "from-secondary/30",
	},
	{
		icon: "tecnologia-icon",
		title: "Tecnología TIER 1",
		copy: "Paneles certificados, microinversores inteligentes y monitoreo 24/7",
		metric: "Garantía 25 años",
		accent: "from-primary/30",
	},
	{
		icon: "hogar-icon",
		title: "Valorización",
		copy: "Aumenta el valor comercial y la categoría energética de tu inmueble",
		metric: "+10% valor",
		accent: "from-secondary/40",
	},
	{
		icon: "hojas-icon",
		title: "Impacto ambiental",
		copy: "Mitiga hasta 10 toneladas de CO₂ por sistema instalado",
		metric: "-10 t CO₂/año",
		accent: "from-primary/20",
	},
];
---

<section id="beneficios" class="py-12 lg:py-24 relative">
	<div
		class="absolute inset-0 -z-10"
		style="background: linear-gradient(145deg, color-mix(in srgb, var(--primary) 90%, black 10%), color-mix(in srgb, var(--primary) 65%, black 35%));"
	></div>
	<div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-secondary/20 to-transparent"></div>
	<div class="max-w-6xl mx-auto px-4 lg:px-8 text-white" data-reveal>
		<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
			<div>
				<p class="text-xs uppercase tracking-[0.5em] text-secondary/80">Beneficios</p>
				<h2 class="text-3xl sm:text-4xl lg:text-5xl font-display leading-tight">Lo que cambia cuando controlas tu energía</h2>
				<p class="text-sm text-white/70 mt-4 max-w-xl">
					Cada proyecto WM SAS combina ingeniería certificada, monitoreo permanente y modelos financieros realistas para garantizar retornos medibles.
				</p>
			</div>
			<a href="#cases" class="inline-flex items-center gap-2 text-sm font-semibold text-secondary">Ver casos reales →</a>
		</div>

		<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-12">
			{items.map((item, index) => (
				<div class="relative rounded-[1.75rem] p-6 border border-white/10 bg-white/5" data-reveal style={`--reveal-delay:${index * 80}ms`}>
					<div class={`absolute inset-0 rounded-[1.75rem] bg-gradient-to-br ${item.accent} to-transparent opacity-60`}></div>
					<div class="relative space-y-5">
						<div class="inline-flex items-center gap-3">
							<div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center text-2xl">
								<Icon name={item.icon} class="text-secondary text-3xl" />
							</div>
							<p class="text-xs uppercase tracking-[0.4em] text-white/60">WM beneficio</p>
						</div>
						<h3 class="text-2xl font-display">{item.title}</h3>
						<p class="text-sm text-white/80">{item.copy}</p>
						<div class="flex items-center justify-between">
							<span class="text-xs uppercase tracking-[0.3em] text-white/60">Indicador</span>
							<span class="text-lg font-display">{item.metric}</span>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
